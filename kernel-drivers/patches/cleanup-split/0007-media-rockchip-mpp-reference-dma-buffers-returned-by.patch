From eafd4d4e56bec758a3a99af3022f0a52680d2c62 Mon Sep 17 00:00:00 2001
From: Yi Ding <yi.s.ding@gmail.com>
Date: Wed, 1 Jul 2026 06:21:26 -0700
Subject: [PATCH 07/65] media: rockchip: mpp: reference DMA buffers returned by
 fd lookup

Plain-language impact:
DMA buffers found by fd can no longer be freed before the caller is done with them.

Kernel details:
mpp_dma_find_buffer_fd() now takes a temporary kref under list_mutex. All callers in this series are adjusted: import consumes the lookup ref, RELEASE_FD drops lookup+import refs, and rkvenc_alloc_task() drops its temporary bs_buf lookup ref.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
Signed-off-by: Yi Ding <yi.s.ding@gmail.com>
---
 drivers/video/rockchip/mpp/mpp_iommu.c   | 84 ++++++++++++++----------
 drivers/video/rockchip/mpp/mpp_rkvenc2.c |  8 +++
 2 files changed, 56 insertions(+), 36 deletions(-)

diff --git a/drivers/video/rockchip/mpp/mpp_iommu.c b/drivers/video/rockchip/mpp/mpp_iommu.c
index cdba2d3499d0..b4258bcfee2d 100644
--- a/drivers/video/rockchip/mpp/mpp_iommu.c
+++ b/drivers/video/rockchip/mpp/mpp_iommu.c
@@ -31,51 +31,55 @@
 #include "mpp_iommu.h"
 #include "mpp_common.h"
 
-struct mpp_dma_buffer *
-mpp_dma_find_buffer_fd(struct mpp_dma_session *dma, int fd)
+static struct mpp_dma_buffer *
+mpp_dma_find_buffer_dmabuf_locked(struct mpp_dma_session *dma,
+				  struct dma_buf *dmabuf)
 {
-	struct dma_buf *dmabuf;
-	struct mpp_dma_buffer *out = NULL;
 	struct mpp_dma_buffer *buffer = NULL, *n;
-	int find = 0;
-
-	dmabuf = dma_buf_get(fd);
-	if (IS_ERR(dmabuf))
-		return NULL;
 
-	mutex_lock(&dma->list_mutex);
-	list_for_each_entry_safe(buffer, n,
-				 &dma->used_list, link) {
+	list_for_each_entry_safe(buffer, n, &dma->used_list, link) {
 		/*
 		 * fd may dup several and point the same dambuf.
 		 * thus, here should be distinguish with the dmabuf.
 		 */
 		if (buffer->dmabuf == dmabuf) {
-			out = buffer;
-			find = 1;
 			list_move_tail(&buffer->link, &buffer->dma->used_list);
-			break;
+			return buffer;
 		}
 	}
-	if (!find) {
-		list_for_each_entry_safe(buffer, n,
-					&dma->static_list, link) {
-			/*
-			 * fd may dup several and point the same dambuf.
-			 * thus, here should be distinguish with the dmabuf.
-			 */
-			if (buffer->dmabuf == dmabuf) {
-				out = buffer;
-				list_move_tail(&buffer->link, &buffer->dma->static_list);
-				break;
-			}
+
+	list_for_each_entry_safe(buffer, n, &dma->static_list, link) {
+		/*
+		 * fd may dup several and point the same dambuf.
+		 * thus, here should be distinguish with the dmabuf.
+		 */
+		if (buffer->dmabuf == dmabuf) {
+			list_move_tail(&buffer->link, &buffer->dma->static_list);
+			return buffer;
 		}
 	}
 
+	return NULL;
+}
+
+struct mpp_dma_buffer *
+mpp_dma_find_buffer_fd(struct mpp_dma_session *dma, int fd)
+{
+	struct dma_buf *dmabuf;
+	struct mpp_dma_buffer *buffer;
+
+	dmabuf = dma_buf_get(fd);
+	if (IS_ERR(dmabuf))
+		return NULL;
+
+	mutex_lock(&dma->list_mutex);
+	buffer = mpp_dma_find_buffer_dmabuf_locked(dma, dmabuf);
+	if (buffer && !kref_get_unless_zero(&buffer->ref))
+		buffer = NULL;
 	mutex_unlock(&dma->list_mutex);
 	dma_buf_put(dmabuf);
 
-	return out;
+	return buffer;
 }
 
 /* Release the buffer from the current list */
@@ -141,17 +145,27 @@ int mpp_dma_release_fd(struct mpp_dma_session *dma, int fd)
 {
 	struct device *dev = dma->dev;
 	struct mpp_dma_buffer *buffer = NULL;
+	struct dma_buf *dmabuf;
 
-	buffer = mpp_dma_find_buffer_fd(dma, fd);
-	if (IS_ERR_OR_NULL(buffer)) {
+	dmabuf = dma_buf_get(fd);
+	if (IS_ERR(dmabuf)) {
 		dev_err(dev, "can not find %d buffer in list\n", fd);
-
 		return -EINVAL;
 	}
 
 	mutex_lock(&dma->list_mutex);
+	buffer = mpp_dma_find_buffer_dmabuf_locked(dma, dmabuf);
+	if (!buffer) {
+		mutex_unlock(&dma->list_mutex);
+		dma_buf_put(dmabuf);
+		dev_err(dev, "can not find %d buffer in list\n", fd);
+
+		return -EINVAL;
+	}
+
 	kref_put(&buffer->ref, mpp_dma_release_buffer);
 	mutex_unlock(&dma->list_mutex);
+	dma_buf_put(dmabuf);
 
 	return 0;
 }
@@ -216,11 +230,9 @@ struct mpp_dma_buffer *mpp_dma_import_fd(struct mpp_iommu_info *iommu_info,
 
 	/* Check whether in dma session */
 	buffer = mpp_dma_find_buffer_fd(dma, fd);
-	if (!IS_ERR_OR_NULL(buffer)) {
-		if (kref_get_unless_zero(&buffer->ref))
-			return buffer;
-		dev_dbg(dma->dev, "missing the fd %d\n", fd);
-	}
+	if (!IS_ERR_OR_NULL(buffer))
+		/* find already took the outside-user reference */
+		return buffer;
 
 	dmabuf = dma_buf_get(fd);
 	if (IS_ERR(dmabuf)) {
diff --git a/drivers/video/rockchip/mpp/mpp_rkvenc2.c b/drivers/video/rockchip/mpp/mpp_rkvenc2.c
index 988151ebf488..0e159d68cce1 100644
--- a/drivers/video/rockchip/mpp/mpp_rkvenc2.c
+++ b/drivers/video/rockchip/mpp/mpp_rkvenc2.c
@@ -1221,6 +1221,14 @@ static void *rkvenc_alloc_task(struct mpp_session *session,
 			if (bs_buf && task->offset_bs > 0)
 				mpp_dma_buf_sync(bs_buf, 0, task->offset_bs, DMA_TO_DEVICE, false);
 			task->bs_buf = bs_buf;
+			/*
+			 * mpp_dma_find_buffer_fd() now returns a temporary
+			 * reference; drop it. task->bs_buf stays valid via the
+			 * buffer's outside import reference (released when the
+			 * task is freed), exactly as before the find-refcount fix.
+			 */
+			if (bs_buf)
+				mpp_dma_release(session->dma, bs_buf);
 		}
 	}
 	rkvenc2_setup_task_id(session->index, task);
-- 
2.53.0

