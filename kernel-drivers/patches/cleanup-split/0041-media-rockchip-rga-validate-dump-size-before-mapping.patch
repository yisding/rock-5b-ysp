From 38264268dc5a87d04245bc10de34f1c757e76783 Mon Sep 17 00:00:00 2001
From: Yi Ding <yi.s.ding@gmail.com>
Date: Wed, 1 Jul 2026 06:21:40 -0700
Subject: [PATCH 41/65] media: rockchip: rga: validate dump size before mapping
 image

Plain-language impact:
Invalid image-dump sizes are rejected before mapping, avoiding a mapping leak.

Kernel details:
Move size assignment and size <= 0 validation before dma_buf_vmap()/vmap() in rga_dump_image_to_file().

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
Signed-off-by: Yi Ding <yi.s.ding@gmail.com>
---
 drivers/video/rockchip/rga3/rga_debugger.c | 13 ++++++-------
 1 file changed, 6 insertions(+), 7 deletions(-)

diff --git a/drivers/video/rockchip/rga3/rga_debugger.c b/drivers/video/rockchip/rga3/rga_debugger.c
index ae3c1c0efed7..f558950fe5da 100644
--- a/drivers/video/rockchip/rga3/rga_debugger.c
+++ b/drivers/video/rockchip/rga3/rga_debugger.c
@@ -881,6 +881,12 @@ static int rga_dump_image_to_file(struct rga_internal_buffer *dump_buffer,
 	void *kvaddr = NULL;
 	void *kvaddr_origin = NULL;
 
+	size = dump_buffer->size;
+	if (size <= 0) {
+		pr_err("dump buffer size[%lx] is invalid!\n", (unsigned long)size);
+		return -EFAULT;
+	}
+
 	switch (dump_buffer->type) {
 	case RGA_DMA_BUFFER:
 	case RGA_DMA_BUFFER_PTR:
@@ -924,18 +930,11 @@ static int rga_dump_image_to_file(struct rga_internal_buffer *dump_buffer,
 		return -EINVAL;
 	}
 
-	size = dump_buffer->size;
-
 	if (kvaddr == NULL) {
 		pr_err("dump addr is NULL!\n");
 		return -EFAULT;
 	}
 
-	if (size <= 0) {
-		pr_err("dump buffer size[%lx] is invalid!\n", (unsigned long)size);
-		return -EFAULT;
-	}
-
 	if (dump_buffer->memory_parm.width == 0 &&
 	    dump_buffer->memory_parm.height == 0)
 		snprintf(file_name, 100, "%s/%d_core%d_%s_plane%d_%s_size%zu_%s.bin",
-- 
2.53.0

