From dab45f8e1e253dcbadc4e6e07a842ca71f17a17c Mon Sep 17 00:00:00 2001
From: Yi Ding <yi.s.ding@gmail.com>
Date: Wed, 1 Jul 2026 06:21:34 -0700
Subject: [PATCH 25/65] media: rockchip: mpp: check service device creation

Plain-language impact:
Service device-node creation failures are now reported and unwound.

Kernel details:
mpp_register_service() checks IS_ERR(srv->child_dev), deletes the cdev, unregisters the chrdev region, and returns PTR_ERR().

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
Signed-off-by: Yi Ding <yi.s.ding@gmail.com>
---
 drivers/video/rockchip/mpp/mpp_service.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/drivers/video/rockchip/mpp/mpp_service.c b/drivers/video/rockchip/mpp/mpp_service.c
index 6303756e0c24..852c0295b863 100644
--- a/drivers/video/rockchip/mpp/mpp_service.c
+++ b/drivers/video/rockchip/mpp/mpp_service.c
@@ -149,6 +149,14 @@ static int mpp_register_service(struct mpp_service *srv,
 
 	srv->child_dev = device_create(srv->cls, dev, srv->dev_id,
 				       NULL, "%s", service_name);
+	if (IS_ERR(srv->child_dev)) {
+		ret = PTR_ERR(srv->child_dev);
+		srv->child_dev = NULL;
+		cdev_del(&srv->mpp_cdev);
+		unregister_chrdev_region(srv->dev_id, 1);
+		dev_err(dev, "create device failed\n");
+		return ret;
+	}
 
 	return 0;
 }
