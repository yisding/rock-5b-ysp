#!/bin/sh
# DKMS: register, build and install the two modules against the running kernel
# (and every future kernel). Then drop the device-tree overlay in place.
set -e
NAME=rk3588-vcodec
VERSION=1.0
OVERLAY=rk3588-rock5b-vcodec

case "$1" in
  configure|abort-upgrade|abort-remove|abort-deconfigure)
    if command -v dkms >/dev/null 2>&1; then
      # add (idempotent), then build+install for the running kernel
      dkms status -m "$NAME" -v "$VERSION" 2>/dev/null | grep -q "$NAME" \
        || dkms add -m "$NAME" -v "$VERSION"
      dkms build  -m "$NAME" -v "$VERSION" || { echo "rk3588-vcodec-dkms: build FAILED (see /var/lib/dkms/$NAME/$VERSION/build/make.log)"; exit 1; }
      dkms install -m "$NAME" -v "$VERSION" --force
    else
      echo "rk3588-vcodec-dkms: dkms not found; install 'dkms' and run: dkms install -m $NAME -v $VERSION" >&2
    fi

    # Device-tree overlay (modules won't bind without it).
    if [ -f "/boot/overlay-user/${OVERLAY}.dtbo" ]; then
      ENVF=/boot/armbianEnv.txt
      if [ -f "$ENVF" ] && grep -qE "^user_overlays=.*${OVERLAY}" "$ENVF"; then
        echo "rk3588-vcodec-dkms: overlay already enabled in $ENVF."
      else
        echo "rk3588-vcodec-dkms: overlay installed. To ENABLE it, add '${OVERLAY}' to"
        echo "  user_overlays= in ${ENVF} (space-separated), then reboot. e.g.:"
        echo "    user_overlays=${OVERLAY}"
        echo "  (not auto-edited, to avoid touching your boot config.)"
      fi
    fi
    ;;
esac
exit 0
