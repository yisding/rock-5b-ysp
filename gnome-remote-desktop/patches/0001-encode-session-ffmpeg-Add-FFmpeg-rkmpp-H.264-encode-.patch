+ * along with this program; if not, write to the Free Software
+ * Foundation, Inc., 59 Temple Place - Suite 330, Boston, MA
+ * 02111-1307, USA.
+ */
+
+#include "config.h"
+
+#include "grd-hwaccel-ffmpeg.h"
+
+#include <fcntl.h>
+#include <gbm.h>
+#include <gio/gio.h>
+#include <glib/gstdio.h>
+#include <inttypes.h>
+#include <libavcodec/avcodec.h>
+
+#include "grd-encode-session-ffmpeg.h"
+#include "grd-vk-device.h"
+
+/*
+ * h264_rkmpp is the only encoder this backend will ever drive. It is looked up
+ * by name (never inferred), so a stock FFmpeg without --enable-rkmpp simply
+ * fails this gate and GRD keeps using VA-API / RFX.
+ */
+#define GRD_RKMPP_ENCODER_NAME "h264_rkmpp"
+
+struct _GrdHwAccelFfmpeg
+{
+  GObject parent;
+
+  GrdVkDevice *vk_device;
+
+  int64_t drm_render_node;
+  int drm_fd;
+  struct gbm_device *gbm_device;
+};
+
+G_DEFINE_TYPE (GrdHwAccelFfmpeg, grd_hwaccel_ffmpeg, G_TYPE_OBJECT)
+
+GrdEncodeSession *
+grd_hwaccel_ffmpeg_create_encode_session (GrdHwAccelFfmpeg  *hwaccel_ffmpeg,
+                                          uint32_t           source_width,
+                                          uint32_t           source_height,
+                                          uint32_t           refresh_rate,
+                                          GError           **error)
+{
+  return (GrdEncodeSession *)
+    grd_encode_session_ffmpeg_new (hwaccel_ffmpeg->vk_device,
+                                   hwaccel_ffmpeg->gbm_device,
+                                   hwaccel_ffmpeg->drm_render_node,
+                                   source_width, source_height,
+                                   refresh_rate, error);
+}
+
+static gboolean
+open_gbm_device (GrdHwAccelFfmpeg  *hwaccel_ffmpeg,
+                 GError           **error)
+{
+  g_autofree char *render_node = NULL;
+
+  render_node = g_strdup_printf ("/dev/dri/renderD%" PRIi64,
+                                 hwaccel_ffmpeg->drm_render_node);
+
+  hwaccel_ffmpeg->drm_fd = g_open (render_node, O_RDWR | O_CLOEXEC, 0);
+  if (hwaccel_ffmpeg->drm_fd == -1)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Failed to open render node %s: %s",
+                   render_node, g_strerror (errno));
+      return FALSE;
+    }
+
+  hwaccel_ffmpeg->gbm_device = gbm_create_device (hwaccel_ffmpeg->drm_fd);
+  if (!hwaccel_ffmpeg->gbm_device)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Failed to create GBM device on %s", render_node);
+      return FALSE;
+    }
+
+  return TRUE;
+}
+
+GrdHwAccelFfmpeg *
+grd_hwaccel_ffmpeg_new (GrdVkDevice  *vk_device,
+                        GError      **error)
+{
+  g_autoptr (GrdHwAccelFfmpeg) hwaccel_ffmpeg = NULL;
+
+  g_assert (vk_device);
+
+  /* Gate 1: the rkmpp encoder must exist in this FFmpeg build. */
+  if (!avcodec_find_encoder_by_name (GRD_RKMPP_ENCODER_NAME))
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                   "FFmpeg encoder \"%s\" is not available",
+                   GRD_RKMPP_ENCODER_NAME);
+      return NULL;
+    }
+
+  hwaccel_ffmpeg = g_object_new (GRD_TYPE_HWACCEL_FFMPEG, NULL);
+  hwaccel_ffmpeg->vk_device = vk_device;
+  hwaccel_ffmpeg->drm_render_node =
+    grd_vk_device_get_drm_render_node (vk_device);
+
+  if (!open_gbm_device (hwaccel_ffmpeg, error))
+    return NULL;
+
+  g_message ("[HWAccel.FFmpeg] Initialized FFmpeg/rkmpp encode backend "
+             "(encoder \"%s\")", GRD_RKMPP_ENCODER_NAME);
+
+  return g_steal_pointer (&hwaccel_ffmpeg);
+}
+
+static void
+grd_hwaccel_ffmpeg_dispose (GObject *object)
+{
+  GrdHwAccelFfmpeg *hwaccel_ffmpeg = GRD_HWACCEL_FFMPEG (object);
+
+  g_clear_pointer (&hwaccel_ffmpeg->gbm_device, gbm_device_destroy);
+  g_clear_fd (&hwaccel_ffmpeg->drm_fd, NULL);
+
+  G_OBJECT_CLASS (grd_hwaccel_ffmpeg_parent_class)->dispose (object);
+}
+
+static void
+grd_hwaccel_ffmpeg_init (GrdHwAccelFfmpeg *hwaccel_ffmpeg)
+{
+  hwaccel_ffmpeg->drm_fd = -1;
+}
+
+static void
+grd_hwaccel_ffmpeg_class_init (GrdHwAccelFfmpegClass *klass)
+{
+  GObjectClass *object_class = G_OBJECT_CLASS (klass);
+
+  object_class->dispose = grd_hwaccel_ffmpeg_dispose;
+}
