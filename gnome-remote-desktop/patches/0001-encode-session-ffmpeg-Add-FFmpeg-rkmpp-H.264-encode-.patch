+#include "config.h"
+
+#include "grd-encode-session-ffmpeg.h"
+
+#include <drm_fourcc.h>
+#include <gbm.h>
+#include <gio/gio.h>
+#include <glib/gstdio.h>
+#include <inttypes.h>
+#include <unistd.h>
+#include <libavcodec/avcodec.h>
+#include <libavutil/buffer.h>
+#include <libavutil/dict.h>
+#include <libavutil/error.h>
+#include <libavutil/frame.h>
+#include <libavutil/hwcontext.h>
+#include <libavutil/hwcontext_drm.h>
+#include <libavutil/pixfmt.h>
+
+#include "grd-avc-frame-info.h"
+#include "grd-bitstream.h"
+#include "grd-image-view-nv12.h"
+#include "grd-utils.h"
+#include "grd-vk-device.h"
+#include "grd-vk-image.h"
+#include "grd-vk-utils.h"
+
+#define GRD_RKMPP_ENCODER_NAME "h264_rkmpp"
+
+/*
+ * Mirrors the VA-API backend's source surface pool sizing rationale: one
+ * surface in flight in the encoder, one in the view creator, one for the
+ * submitted pending frame and one to prepare the next pending frame.
+ */
+#define N_SRC_SURFACES 8
+
+/* Mirror the VA-API backend's fixed QP and reported quality. */
+#define FIXED_QP 22
+#define QUALITY_VALUE 100
+
+/*
+ * Fallback target bitrate (~0.1 bits per pixel per frame, capped) used only by
+ * FFmpeg builds whose rkmpp encoder lacks a fixed-QP rate-control mode - i.e.
+ * mainline's h264_rkmpp, which only offers vbr/cbr/avbr and no QP knob.
+ * ffmpeg-rockchip encodes at fixed QP (see create_encoder) and ignores this.
+ */
+#define FALLBACK_BPP_DIVISOR 10
+#define FALLBACK_BITRATE_CAP_BPS 100000000
+
+/* High profile, matching VAProfileH264High / the NAL writer's profile_idc. */
+#ifndef AV_PROFILE_H264_HIGH
+#define AV_PROFILE_H264_HIGH FF_PROFILE_H264_HIGH
+#endif
+
+typedef struct
+{
+  GrdEncodeSessionFfmpeg *encode_session_ffmpeg;
+
+  struct gbm_bo *bo;
+  int fd;
+
+  GrdImageView *image_view;
+
+  /*
+   * Prebuilt descriptor handed to the encoder for every frame using this
+   * surface. It references the (persistent) dma-buf fd above, so it outlives
+   * any AVFrame that points at it.
+   */
+  AVDRMFrameDescriptor drm_desc;
+} NV12Surface;
+
+struct _GrdEncodeSessionFfmpeg
+{
+  GrdEncodeSession parent;
+
+  GrdVkDevice *vk_device;
+  struct gbm_device *gbm_device; /* Not owned */
+  int64_t drm_render_node;
+
+  uint32_t surface_width;
+  uint32_t surface_height;
+  uint32_t refresh_rate;
+
+  AVCodecContext *avctx;
+  AVBufferRef *hw_device_ctx; /* May be NULL */
+  AVBufferRef *hw_frames_ctx; /* May be NULL */
+
+  int64_t next_pts;
+  gboolean force_next_idr;
+
+  GHashTable *surfaces; /* GrdImageView -> NV12Surface */
+
+  GMutex pending_frames_mutex;
+  GHashTable *pending_frames; /* GrdImageView -> AVFrame */
+
+  GMutex bitstreams_mutex;
+  GHashTable *bitstreams; /* GrdBitstream -> AVPacket */
+};
+
+G_DEFINE_TYPE (GrdEncodeSessionFfmpeg, grd_encode_session_ffmpeg,
+               GRD_TYPE_ENCODE_SESSION)
+
+static void
+set_av_error (GError    **error,
+              int         av_errnum,
+              const char *message)
+{
+  char av_error[AV_ERROR_MAX_STRING_SIZE] = { 0 };
+
+  av_strerror (av_errnum, av_error, sizeof (av_error));
+  g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED, "%s: %s",
+               message, av_error);
+}
+
+static void
+nv12_surface_free (NV12Surface *surface)
+{
+  g_clear_object (&surface->image_view);
+  g_clear_fd (&surface->fd, NULL);
+  g_clear_pointer (&surface->bo, gbm_bo_destroy);
+  g_free (surface);
+}
+
+static NV12Surface *
+nv12_surface_new (GrdEncodeSessionFfmpeg  *self,
+                  GError                 **error)
+{
+  uint32_t width = self->surface_width;
+  uint32_t height = self->surface_height;
+  g_autoptr (GrdVkImage) vk_y_layer = NULL;
+  g_autoptr (GrdVkImage) vk_uv_layer = NULL;
+  GrdImageViewNV12 *image_view_nv12;
+  NV12Surface *surface;
+  struct gbm_bo *bo;
+  uint32_t offsets[2];
+  uint32_t strides[2];
+  uint64_t modifier;
+  int plane_count;
+  int fd = -1;
+  off_t bo_size;
+
+  g_assert (width % 16 == 0 && width >= 16);
+  g_assert (height % 16 == 0 && height >= 16);
+
+  bo = gbm_bo_create (self->gbm_device, width, height, GBM_FORMAT_NV12,
+                      GBM_BO_USE_RENDERING | GBM_BO_USE_LINEAR);
+  if (!bo)
+    {
+      bo = gbm_bo_create (self->gbm_device, width, height, GBM_FORMAT_NV12,
+                          GBM_BO_USE_LINEAR);
+    }
+  if (!bo)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Failed to allocate %ux%u linear NV12 GBM buffer",
+                   width, height);
+      return NULL;
+    }
+
+  plane_count = gbm_bo_get_plane_count (bo);
+  if (plane_count != 2)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Unexpected NV12 GBM plane count %i (expected 2)",
+                   plane_count);
+      gbm_bo_destroy (bo);
+      return NULL;
+    }
+
+  modifier = gbm_bo_get_modifier (bo);
+  if (modifier == DRM_FORMAT_MOD_INVALID)
+    modifier = DRM_FORMAT_MOD_LINEAR;
+  if (modifier != DRM_FORMAT_MOD_LINEAR)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                   "GBM returned non-linear NV12 modifier 0x%" PRIx64
+                   "; only DRM_FORMAT_MOD_LINEAR is supported", modifier);
+      gbm_bo_destroy (bo);
+      return NULL;
+    }
+
+  offsets[0] = gbm_bo_get_offset (bo, 0);
+  offsets[1] = gbm_bo_get_offset (bo, 1);
+  strides[0] = gbm_bo_get_stride_for_plane (bo, 0);
+  strides[1] = gbm_bo_get_stride_for_plane (bo, 1);
+
+  fd = gbm_bo_get_fd (bo);
+  if (fd < 0)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Failed to export GBM buffer as a dma-buf");
+      gbm_bo_destroy (bo);
+      return NULL;
+    }
+
+  bo_size = lseek (fd, 0, SEEK_END);
+  if (bo_size <= 0)
+    bo_size = (off_t) offsets[1] + (off_t) strides[1] * (height / 2);
+
+  /*
+   * Import the same dma-buf into Vulkan as two single-plane images, exactly
+   * like the VA-API backend does with its exported surface. grd_vk_dma_buf_image_new
+   * dups the fd internally, so the fd stays ours for the MPP descriptor.
+   */
+  vk_y_layer = grd_vk_dma_buf_image_new (self->vk_device, VK_FORMAT_R8_UNORM,
+                                         width, height,
+                                         VK_IMAGE_USAGE_STORAGE_BIT, fd,
+                                         offsets[0], strides[0], modifier,
+                                         error);
+  if (!vk_y_layer)
+    {
+      g_clear_fd (&fd, NULL);
+      gbm_bo_destroy (bo);
+      return NULL;
+    }
+
+  vk_uv_layer = grd_vk_dma_buf_image_new (self->vk_device, VK_FORMAT_R8G8_UNORM,
+                                          width / 2, height / 2,
+                                          VK_IMAGE_USAGE_STORAGE_BIT, fd,
+                                          offsets[1], strides[1], modifier,
+                                          error);
+  if (!vk_uv_layer)
+    {
+      g_clear_fd (&fd, NULL);
+      gbm_bo_destroy (bo);
+      return NULL;
+    }
+
+  image_view_nv12 = grd_image_view_nv12_new (g_steal_pointer (&vk_y_layer),
+                                             g_steal_pointer (&vk_uv_layer));
+
+  surface = g_new0 (NV12Surface, 1);
+  surface->encode_session_ffmpeg = self;
+  surface->bo = bo;
+  surface->fd = fd;
+  surface->image_view = GRD_IMAGE_VIEW (image_view_nv12);
+
+  surface->drm_desc.nb_objects = 1;
+  surface->drm_desc.objects[0].fd = fd;
+  surface->drm_desc.objects[0].size = bo_size;
+  surface->drm_desc.objects[0].format_modifier = modifier;
+  surface->drm_desc.nb_layers = 1;
+  surface->drm_desc.layers[0].format = DRM_FORMAT_NV12;
+  surface->drm_desc.layers[0].nb_planes = 2;
+  surface->drm_desc.layers[0].planes[0].object_index = 0;
+  surface->drm_desc.layers[0].planes[0].offset = offsets[0];
+  surface->drm_desc.layers[0].planes[0].pitch = strides[0];
+  surface->drm_desc.layers[0].planes[1].object_index = 0;
+  surface->drm_desc.layers[0].planes[1].offset = offsets[1];
+  surface->drm_desc.layers[0].planes[1].pitch = strides[1];
+
+  return surface;
+}
+
+static void
+drm_desc_buffer_noop_free (void    *opaque,
+                           uint8_t *data)
+{
+  /*
+   * The descriptor lives in its NV12Surface, which outlives every AVFrame that
+   * references it (a surface is only reused once its frame has been locked and
+   * unlocked). Nothing to free here.
+   */
+}
+
+static AVFrame *
+build_av_frame (GrdEncodeSessionFfmpeg  *self,
+                NV12Surface             *surface,
+                gboolean                 force_idr,
+                GError                 **error)
+{
+  AVFrame *frame;
+
+  frame = av_frame_alloc ();
+  if (!frame)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Failed to allocate AVFrame");
+      return NULL;
+    }
+
+  frame->format = AV_PIX_FMT_DRM_PRIME;
+  frame->width = self->surface_width;
+  frame->height = self->surface_height;
+  frame->pts = self->next_pts++;
+
+  frame->buf[0] = av_buffer_create ((uint8_t *) &surface->drm_desc,
+                                    sizeof (AVDRMFrameDescriptor),
+                                    drm_desc_buffer_noop_free, NULL,
+                                    AV_BUFFER_FLAG_READONLY);
+  if (!frame->buf[0])
+    {
+      av_frame_free (&frame);
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Failed to wrap DRM frame descriptor");
+      return NULL;
+    }
+  frame->data[0] = frame->buf[0]->data;
+
+  if (self->hw_frames_ctx)
+    frame->hw_frames_ctx = av_buffer_ref (self->hw_frames_ctx);
+
+  if (force_idr)
+    {
+      frame->pict_type = AV_PICTURE_TYPE_I;
+#ifdef AV_FRAME_FLAG_KEY
+      frame->flags |= AV_FRAME_FLAG_KEY;
+#else
+      frame->key_frame = 1;
+#endif
+    }
+
+  return frame;
+}
+
+/* Runs on the base-class encode thread (lock_bitstream) and, once, during
+ * construction (smoke test). Never concurrently with itself. */
+static AVPacket *
+encode_and_receive (GrdEncodeSessionFfmpeg  *self,
+                    AVFrame                 *frame,
+                    GError                 **error)
+{
+  AVPacket *packet;
+  int ret;
+
+  ret = avcodec_send_frame (self->avctx, frame);
+  if (ret < 0)
+    {
+      set_av_error (error, ret, "Failed to send frame to encoder");
+      return NULL;
+    }
+
+  packet = av_packet_alloc ();
+  if (!packet)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Failed to allocate AVPacket");
+      return NULL;
+    }
+
+  ret = avcodec_receive_packet (self->avctx, packet);
+  if (ret < 0)
+    {
+      av_packet_free (&packet);
+      if (ret == AVERROR (EAGAIN))
+        {
+          g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                       "Encoder produced no packet for the submitted frame "
+                       "(EAGAIN); h264_rkmpp must operate 1-in-1-out for "
+                       "low-latency encoding");
+        }
+      else
+        {
+          set_av_error (error, ret, "Failed to receive packet from encoder");
+        }
+      return NULL;
+    }
+
+  return packet;
+}
+
+static void
+grd_encode_session_ffmpeg_get_surface_size (GrdEncodeSession *encode_session,
+                                            uint32_t         *surface_width,
+                                            uint32_t         *surface_height)
+{
+  GrdEncodeSessionFfmpeg *self = GRD_ENCODE_SESSION_FFMPEG (encode_session);
+
+  g_assert (self->surface_width % 16 == 0 && self->surface_width >= 16);
+  g_assert (self->surface_height % 16 == 0 && self->surface_height >= 16);
+
+  *surface_width = self->surface_width;
+  *surface_height = self->surface_height;
+}
+
+static GList *
+grd_encode_session_ffmpeg_get_image_views (GrdEncodeSession *encode_session)
+{
+  GrdEncodeSessionFfmpeg *self = GRD_ENCODE_SESSION_FFMPEG (encode_session);
+
+  return g_hash_table_get_keys (self->surfaces);
+}
+
+static gboolean
+grd_encode_session_ffmpeg_has_pending_frames (GrdEncodeSession *encode_session)
+{
+  GrdEncodeSessionFfmpeg *self = GRD_ENCODE_SESSION_FFMPEG (encode_session);
+  g_autoptr (GMutexLocker) locker = NULL;
+
+  locker = g_mutex_locker_new (&self->pending_frames_mutex);
+  return g_hash_table_size (self->pending_frames) > 0;
+}
+
+static gboolean
+grd_encode_session_ffmpeg_encode_frame (GrdEncodeSession  *encode_session,
+                                        GrdEncodeContext  *encode_context,
+                                        GrdImageView      *image_view,
+                                        GError           **error)
+{
+  GrdEncodeSessionFfmpeg *self = GRD_ENCODE_SESSION_FFMPEG (encode_session);
+  NV12Surface *surface = NULL;
+  AVFrame *frame;
+  gboolean force_idr;
+
+  if (!g_hash_table_lookup_extended (self->surfaces, image_view,
+                                     NULL, (gpointer *) &surface))
+    g_assert_not_reached ();
+  g_assert (surface);
+
+  g_mutex_lock (&self->pending_frames_mutex);
+  g_assert (!g_hash_table_contains (self->pending_frames, image_view));
+  g_mutex_unlock (&self->pending_frames_mutex);
+
+  force_idr = self->force_next_idr;
+  self->force_next_idr = FALSE;
+
+  /*
+   * Only build the AVFrame here (renderer thread); the actual avcodec calls
+   * happen in lock_bitstream on the base-class encode thread, so the
+   * AVCodecContext is only ever touched from a single thread.
+   */
+  frame = build_av_frame (self, surface, force_idr, error);
+  if (!frame)
+    return FALSE;
+
+  g_mutex_lock (&self->pending_frames_mutex);
+  g_hash_table_insert (self->pending_frames, image_view, frame);
+  g_mutex_unlock (&self->pending_frames_mutex);
+
+  return TRUE;
+}
+
+static GrdBitstream *
+grd_encode_session_ffmpeg_lock_bitstream (GrdEncodeSession  *encode_session,
+                                          GrdImageView      *image_view,
+                                          GError           **error)
+{
+  GrdEncodeSessionFfmpeg *self = GRD_ENCODE_SESSION_FFMPEG (encode_session);
+  AVFrame *frame = NULL;
+  AVPacket *packet;
+  GrdBitstream *bitstream;
+  GrdAVCFrameInfo *avc_frame_info;
+  GrdAVCFrameType frame_type;
+
+  g_mutex_lock (&self->pending_frames_mutex);
+  if (!g_hash_table_steal_extended (self->pending_frames, image_view,
+                                    NULL, (gpointer *) &frame))
+    g_assert_not_reached ();
+  g_mutex_unlock (&self->pending_frames_mutex);
+  g_assert (frame);
+
+  packet = encode_and_receive (self, frame, error);
+  av_frame_free (&frame);
+  if (!packet)
+    return NULL;
+
+  frame_type = (packet->flags & AV_PKT_FLAG_KEY) ? GRD_AVC_FRAME_TYPE_I
+                                                 : GRD_AVC_FRAME_TYPE_P;
+
+  /* The packet owns the bitstream memory; keep it alive until unlock. */
+  bitstream = grd_bitstream_new (packet->data, packet->size);
+  avc_frame_info = grd_avc_frame_info_new (frame_type, FIXED_QP, QUALITY_VALUE);
+  grd_bitstream_set_avc_frame_info (bitstream, avc_frame_info);
+
+  g_mutex_lock (&self->bitstreams_mutex);
+  g_hash_table_insert (self->bitstreams, bitstream, packet);
+  g_mutex_unlock (&self->bitstreams_mutex);
+
+  return bitstream;
+}
+
+static gboolean
+grd_encode_session_ffmpeg_unlock_bitstream (GrdEncodeSession  *encode_session,
+                                            GrdBitstream      *bitstream,
+                                            GError           **error)
+{
+  GrdEncodeSessionFfmpeg *self = GRD_ENCODE_SESSION_FFMPEG (encode_session);
+  AVPacket *packet = NULL;
+
+  g_mutex_lock (&self->bitstreams_mutex);
+  if (!g_hash_table_steal_extended (self->bitstreams, bitstream,
+                                    NULL, (gpointer *) &packet))
+    g_assert_not_reached ();
+  g_mutex_unlock (&self->bitstreams_mutex);
+  g_assert (packet);
+
+  av_packet_free (&packet);
+  grd_bitstream_free (bitstream);
+
+  return TRUE;
+}
+
+static gboolean
+create_encoder (GrdEncodeSessionFfmpeg  *self,
+                GError                 **error)
+{
+  const AVCodec *codec;
+  AVDictionary *opts = NULL;
+  const AVDictionaryEntry *entry = NULL;
+  g_autofree char *render_node = NULL;
+  int ret;
+
+  /* Gate 1: only ever the rkmpp encoder, looked up by name. */
+  codec = avcodec_find_encoder_by_name (GRD_RKMPP_ENCODER_NAME);
+  if (!codec)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                   "FFmpeg encoder \"%s\" is not available",
+                   GRD_RKMPP_ENCODER_NAME);
+      return FALSE;
+    }
+
+  self->avctx = avcodec_alloc_context3 (codec);
+  if (!self->avctx)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                   "Failed to allocate codec context");
+      return FALSE;
+    }
+
+  self->avctx->width = self->surface_width;
+  self->avctx->height = self->surface_height;
+  self->avctx->pix_fmt = AV_PIX_FMT_DRM_PRIME;
+  /*
+   * The DRM-PRIME surfaces wrap NV12. Declaring the software format explicitly
+   * is required by ffmpeg-rockchip, which maps avctx->sw_pix_fmt (not the DRM
+   * descriptor) to the MPP input format; on mainline it must simply agree with
+   * the hw_frames_ctx sw_format set below.
+   */
+  self->avctx->sw_pix_fmt = AV_PIX_FMT_NV12;
+  self->avctx->time_base = (AVRational) { 1, (int) self->refresh_rate };
+  self->avctx->framerate = (AVRational) { (int) self->refresh_rate, 1 };
+  /* Effectively infinite GOP: only the forced first frame is an IDR, the rest
+   * are P-frames, mirroring the VA-API backend. Client refresh is driven by
+   * render-context recreation. */
+  self->avctx->gop_size = (int) (MAX (self->refresh_rate, 1u) * 3600);
+  self->avctx->max_b_frames = 0;
+  self->avctx->refs = 1;
+  self->avctx->profile = AV_PROFILE_H264_HIGH;
+  self->avctx->color_range = AVCOL_RANGE_MPEG;
+  self->avctx->thread_count = 1;
+  /*
+   * Load-bearing for ffmpeg-rockchip: without AV_CODEC_FLAG_LOW_DELAY its
+   * encoder runs asynchronously (buffering several frames before the first
+   * packet), which would break our strict 1-in-1-out lock_bitstream model and
+   * the startup smoke encode. With the flag it submits and blocks for each
+   * frame's packet. Mainline's encoder is 1-in-1-out regardless; the flag is
+   * harmless there.
+   */
+  self->avctx->flags |= AV_CODEC_FLAG_LOW_DELAY;
+
+  /*
+   * Fallback rate control for builds without a fixed-QP mode (mainline). In
+   * fixed-QP builds (ffmpeg-rockchip) this is ignored; there the QP set below
+   * governs quality. Computed once from the surface geometry and refresh rate.
+   */
+  self->avctx->bit_rate =
+    MIN ((int64_t) self->surface_width * self->surface_height *
+         self->refresh_rate / FALLBACK_BPP_DIVISOR,
+         (int64_t) FALLBACK_BITRATE_CAP_BPS);
+
+  /*
+   * Best-effort DRM hw device + frames context. rkmpp imports DRM-PRIME
+   * descriptors directly, but some FFmpeg builds additionally want these set;
+   * if the DRM hwcontext cannot be initialized we fall back to feeding bare
+   * DRM-PRIME frames.
+   */
+  render_node = g_strdup_printf ("/dev/dri/renderD%" PRIi64,
+                                 self->drm_render_node);
+  if (av_hwdevice_ctx_create (&self->hw_device_ctx, AV_HWDEVICE_TYPE_DRM,
+                              render_node, NULL, 0) >= 0)
+    {
+      self->hw_frames_ctx = av_hwframe_ctx_alloc (self->hw_device_ctx);
+      if (self->hw_frames_ctx)
+        {
+          AVHWFramesContext *frames =
+            (AVHWFramesContext *) self->hw_frames_ctx->data;
+
+          frames->format = AV_PIX_FMT_DRM_PRIME;
+          frames->sw_format = AV_PIX_FMT_NV12;
+          frames->width = self->surface_width;
+          frames->height = self->surface_height;
+          frames->initial_pool_size = 0;
+
+          if (av_hwframe_ctx_init (self->hw_frames_ctx) < 0)
+            {
+              g_debug ("[HWAccel.FFmpeg] DRM hw frames context unavailable; "
+                       "feeding bare DRM-PRIME frames");
+              av_buffer_unref (&self->hw_frames_ctx);
+            }
+        }
+
+      self->avctx->hw_device_ctx = av_buffer_ref (self->hw_device_ctx);
+      if (self->hw_frames_ctx)
+        self->avctx->hw_frames_ctx = av_buffer_ref (self->hw_frames_ctx);
+    }
+  else
+    {
+      g_debug ("[HWAccel.FFmpeg] DRM hw device context unavailable; "
+               "feeding bare DRM-PRIME frames");
+    }
+
+  /*
+   * Constant-quality fixed QP, mirroring the VA-API backend.
+   *
+   * We set only "qp_init" and deliberately never name the rate-control mode:
+   *  - ffmpeg-rockchip: "qp_init" is a known option, and with the rate-control
+   *    mode left at its default the encoder auto-selects fixed QP (its "CQP"
+   *    mode) as soon as qp_init >= 0. Naming the mode would be fragile - its
+   *    fixed-QP constant is spelled "CQP", not "fixqp", and passing an invalid
+   *    value for a *known* option makes avcodec_open2() fail outright rather
+   *    than being ignored.
+   *  - mainline: the rkmpp encoder has neither a fixed-QP mode nor a "qp_init"
+   *    option, so this is an unknown option - tolerated (left in the dict and
+   *    logged below), with the fallback bit_rate above driving its rate control.
+   *
+   * Unknown options are only logged; the smoke encode is the authoritative
+   * low-latency / zero-copy gate.
+   */
+  av_dict_set_int (&opts, "qp_init", FIXED_QP, 0);
+
+  ret = avcodec_open2 (self->avctx, codec, &opts);
+  if (ret < 0)
+    {
+      av_dict_free (&opts);
+      set_av_error (error, ret, "Failed to open h264_rkmpp encoder");
+      return FALSE;
+    }
+
+  while ((entry = av_dict_get (opts, "", entry, AV_DICT_IGNORE_SUFFIX)))
+    {
+      g_debug ("[HWAccel.FFmpeg] Encoder ignored option \"%s\"=\"%s\"",
+               entry->key, entry->value);
+    }
+  av_dict_free (&opts);
+
+  /* Gate 4: the no-B-frame low-latency setting must have been honoured. */
+  if (self->avctx->max_b_frames != 0)
+    {
+      g_set_error (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                   "Encoder did not honour the no-B-frame low-latency setting "
+                   "(max_b_frames=%i)", self->avctx->max_b_frames);
+      return FALSE;
+    }
+
+  return TRUE;
+}
+
+static gboolean
+allocate_surfaces (GrdEncodeSessionFfmpeg  *self,
+                   GError                 **error)
+{
+  uint32_t i;
+
+  for (i = 0; i < N_SRC_SURFACES; ++i)
+    {
+      NV12Surface *surface;
+
+      surface = nv12_surface_new (self, error);
+      if (!surface)
+        return FALSE;
+
+      g_hash_table_insert (self->surfaces, surface->image_view, surface);
+    }
+
+  return TRUE;
+}
+
+static gboolean
+run_smoke_test (GrdEncodeSessionFfmpeg  *self,
+                NV12Surface             *surface,
+                GError                 **error)
+{
+  AVFrame *frame;
+  AVPacket *packet;
+
+  /*
+   * Gate 5: prove that zero-copy DRM-PRIME import actually works by importing a
+   * real dma-buf and running a single encode. Its (garbage) output is dropped;
+   * the next, first real frame is forced to IDR so the stream starts clean.
+   */
+  frame = build_av_frame (self, surface, TRUE, error);
+  if (!frame)
+    return FALSE;
+
+  packet = encode_and_receive (self, frame, error);
+  av_frame_free (&frame);
+  if (!packet)
+    {
+      g_prefix_error (error, "Zero-copy DRM-PRIME smoke encode failed: ");
+      return FALSE;
+    }
+
+  av_packet_free (&packet);
+
+  self->force_next_idr = TRUE;
+
+  return TRUE;
+}
+
+GrdEncodeSessionFfmpeg *
+grd_encode_session_ffmpeg_new (GrdVkDevice        *vk_device,
+                               struct gbm_device  *gbm_device,
+                               int64_t             drm_render_node,
+                               uint32_t            source_width,
+                               uint32_t            source_height,
+                               uint32_t            refresh_rate,
+                               GError            **error)
+{
+  g_autoptr (GrdEncodeSessionFfmpeg) self = NULL;
+  NV12Surface *first_surface = NULL;
+  GHashTableIter iter;
+
+  g_assert (vk_device);
+  g_assert (gbm_device);
+
+  self = g_object_new (GRD_TYPE_ENCODE_SESSION_FFMPEG, NULL);
+  self->vk_device = vk_device;
+  self->gbm_device = gbm_device;
+  self->drm_render_node = drm_render_node;
+  self->refresh_rate = refresh_rate > 0 ? refresh_rate : 60;
+  self->surface_width = grd_get_aligned_size (source_width, 16);
+  self->surface_height = grd_get_aligned_size (source_height, 16);
+
+  if (!create_encoder (self, error))
+    return NULL;
+
+  if (!allocate_surfaces (self, error))
+    return NULL;
+
+  g_hash_table_iter_init (&iter, self->surfaces);
+  if (!g_hash_table_iter_next (&iter, NULL, (gpointer *) &first_surface))
+    g_assert_not_reached ();
+
+  if (!run_smoke_test (self, first_surface, error))
+    return NULL;
+
+  g_message ("[HWAccel.FFmpeg] Created h264_rkmpp encode session for surface "
+             "with size %ux%u (encoder dimensions %ux%u)",
+             source_width, source_height,
+             self->surface_width, self->surface_height);
+
+  return g_steal_pointer (&self);
+}
+
+static void
+grd_encode_session_ffmpeg_dispose (GObject *object)
+{
+  GrdEncodeSessionFfmpeg *self = GRD_ENCODE_SESSION_FFMPEG (object);
+
+  g_assert (g_hash_table_size (self->bitstreams) == 0);
+  g_assert (g_hash_table_size (self->pending_frames) == 0);
+
+  g_clear_pointer (&self->surfaces, g_hash_table_unref);
+
+  av_buffer_unref (&self->hw_frames_ctx);
+  av_buffer_unref (&self->hw_device_ctx);
+  avcodec_free_context (&self->avctx);
+
+  G_OBJECT_CLASS (grd_encode_session_ffmpeg_parent_class)->dispose (object);
+}
+
+static void
+grd_encode_session_ffmpeg_finalize (GObject *object)
+{
+  GrdEncodeSessionFfmpeg *self = GRD_ENCODE_SESSION_FFMPEG (object);
+
+  g_mutex_clear (&self->pending_frames_mutex);
+  g_mutex_clear (&self->bitstreams_mutex);
+
+  g_clear_pointer (&self->pending_frames, g_hash_table_unref);
+  g_clear_pointer (&self->bitstreams, g_hash_table_unref);
+
+  G_OBJECT_CLASS (grd_encode_session_ffmpeg_parent_class)->finalize (object);
+}
+
+static void
+grd_encode_session_ffmpeg_init (GrdEncodeSessionFfmpeg *self)
+{
+  self->surfaces =
+    g_hash_table_new_full (NULL, NULL, NULL,
+                           (GDestroyNotify) nv12_surface_free);
+  self->pending_frames = g_hash_table_new (NULL, NULL);
+  self->bitstreams = g_hash_table_new (NULL, NULL);
+
+  g_mutex_init (&self->pending_frames_mutex);
+  g_mutex_init (&self->bitstreams_mutex);
+}
+
+static void
+grd_encode_session_ffmpeg_class_init (GrdEncodeSessionFfmpegClass *klass)
+{
+  GObjectClass *object_class = G_OBJECT_CLASS (klass);
+  GrdEncodeSessionClass *encode_session_class =
+    GRD_ENCODE_SESSION_CLASS (klass);
+
+  object_class->dispose = grd_encode_session_ffmpeg_dispose;
+  object_class->finalize = grd_encode_session_ffmpeg_finalize;
+
+  encode_session_class->get_surface_size =
+    grd_encode_session_ffmpeg_get_surface_size;
+  encode_session_class->get_image_views =
+    grd_encode_session_ffmpeg_get_image_views;
+  encode_session_class->has_pending_frames =
+    grd_encode_session_ffmpeg_has_pending_frames;
+  encode_session_class->encode_frame =
+    grd_encode_session_ffmpeg_encode_frame;
+  encode_session_class->lock_bitstream =
+    grd_encode_session_ffmpeg_lock_bitstream;
+  encode_session_class->unlock_bitstream =
+    grd_encode_session_ffmpeg_unlock_bitstream;
+}
