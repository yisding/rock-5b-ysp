From 03cf568e386bdf86cbdba289c1de234be256fd32 Mon Sep 17 00:00:00 2001
From: Yi Ding <yi.s.ding@gmail.com>
Date: Mon, 29 Jun 2026 22:48:07 -0700
Subject: [PATCH] hwaccel-vulkan: Query the base DRM format modifier list

grd_hwaccel_vulkan_get_modifiers_for_format() queried
VkDrmFormatModifierPropertiesList2EXT, the "List2" variant added in
revision 2 of VK_EXT_image_drm_format_modifier. Mesa's panvk advertises
revision 2 but only populates the base
VkDrmFormatModifierPropertiesListEXT, leaving List2 empty. GRD therefore
found no modifiers for the capture format on Mali, rejected the physical
device, and disabled all hardware encoding (both VA-API and
FFmpeg/rkmpp), silently falling back to software RFX.

Query the base list instead. It carries the same modifiers and is
implemented by every driver supporting the extension, so this keeps
working on drivers that do populate List2 (e.g. lavapipe) too.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01EN9JjFVPvgho9JggxZbM7Y
---
 src/grd-hwaccel-vulkan.c | 36 ++++++++++++++++++++++--------------
 1 file changed, 22 insertions(+), 14 deletions(-)

diff --git a/src/grd-hwaccel-vulkan.c b/src/grd-hwaccel-vulkan.c
index c188fa7..0b7bbf2 100644
--- a/src/grd-hwaccel-vulkan.c
+++ b/src/grd-hwaccel-vulkan.c
@@ -83,8 +83,8 @@ get_egl_vulkan_format_modifier_intersection (GrdHwAccelVulkan       *hwaccel_vul
 {
   GrdEglThread *egl_thread = hwaccel_vulkan->egl_thread;
   VkFormatProperties2 format_properties_2 = {};
-  VkDrmFormatModifierPropertiesList2EXT modifier_properties_list2 = {};
-  g_autofree VkDrmFormatModifierProperties2EXT *modifier_properties_2 = NULL;
+  VkDrmFormatModifierPropertiesListEXT modifier_properties_list = {};
+  g_autofree VkDrmFormatModifierPropertiesEXT *modifier_properties = NULL;
   VkFormat vk_format = VK_FORMAT_UNDEFINED;
   g_autofree uint64_t *egl_modifiers = NULL;
   int n_egl_modifiers;
@@ -94,16 +94,24 @@ get_egl_vulkan_format_modifier_intersection (GrdHwAccelVulkan       *hwaccel_vul
   if (!grd_vk_get_vk_format_from_drm_format (drm_format, &vk_format, error))
     return NULL;
 
+  /*
+   * Query the base VkDrmFormatModifierPropertiesListEXT, not the newer "...List2"
+   * variant: panvk (Mesa) advertises VK_EXT_image_drm_format_modifier revision 2
+   * yet only populates the base list, returning an empty List2. Using List2 here
+   * made GRD reject the Mali device (no modifiers for the capture format) and
+   * disabled all hardware encoding. The base list carries the same modifiers and
+   * is implemented by every driver supporting the extension.
+   */
   format_properties_2.sType = VK_STRUCTURE_TYPE_FORMAT_PROPERTIES_2;
-  modifier_properties_list2.sType =
-    VK_STRUCTURE_TYPE_DRM_FORMAT_MODIFIER_PROPERTIES_LIST_2_EXT;
+  modifier_properties_list.sType =
+    VK_STRUCTURE_TYPE_DRM_FORMAT_MODIFIER_PROPERTIES_LIST_EXT;
 
-  grd_vk_append_to_chain (&format_properties_2, &modifier_properties_list2);
+  grd_vk_append_to_chain (&format_properties_2, &modifier_properties_list);
 
   vkGetPhysicalDeviceFormatProperties2 (vk_physical_device, vk_format,
                                         &format_properties_2);
 
-  if (modifier_properties_list2.drmFormatModifierCount == 0)
+  if (modifier_properties_list.drmFormatModifierCount == 0)
     {
       g_set_error (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
                    "No DRM format modifiers available for DRM format %u",
@@ -111,11 +119,11 @@ get_egl_vulkan_format_modifier_intersection (GrdHwAccelVulkan       *hwaccel_vul
       return NULL;
     }
 
-  modifier_properties_2 =
-    g_new0 (VkDrmFormatModifierProperties2EXT,
-            modifier_properties_list2.drmFormatModifierCount);
+  modifier_properties =
+    g_new0 (VkDrmFormatModifierPropertiesEXT,
+            modifier_properties_list.drmFormatModifierCount);
 
-  modifier_properties_list2.pDrmFormatModifierProperties = modifier_properties_2;
+  modifier_properties_list.pDrmFormatModifierProperties = modifier_properties;
   vkGetPhysicalDeviceFormatProperties2 (vk_physical_device, vk_format,
                                         &format_properties_2);
 
@@ -131,12 +139,12 @@ get_egl_vulkan_format_modifier_intersection (GrdHwAccelVulkan       *hwaccel_vul
 
   vk_modifiers = g_array_new (FALSE, FALSE, sizeof (uint64_t));
 
-  for (i = 0; i < modifier_properties_list2.drmFormatModifierCount; i++)
+  for (i = 0; i < modifier_properties_list.drmFormatModifierCount; i++)
     {
-      uint64_t modifier = modifier_properties_2[i].drmFormatModifier;
-      uint32_t n_planes = modifier_properties_2[i].drmFormatModifierPlaneCount;
+      uint64_t modifier = modifier_properties[i].drmFormatModifier;
+      uint32_t n_planes = modifier_properties[i].drmFormatModifierPlaneCount;
       VkFormatFeatureFlags2 tiling_features =
-        modifier_properties_2[i].drmFormatModifierTilingFeatures;
+        modifier_properties[i].drmFormatModifierTilingFeatures;
 
       if (required_n_planes &&
           n_planes != *required_n_planes)
-- 
