+static void RGA_set_reg_mosaic(u8 *base, struct rga2_req *msg)
+{
+	u32 *bRGA_MOSAIC_MODE;
+
+	bRGA_MOSAIC_MODE = (u32 *)(base + RGA2_MOSAIC_MODE_OFFSET);
+
+	*bRGA_MOSAIC_MODE = (u32)(msg->mosaic_info.mode & 0x7);
+}
