+int rkvdec_link_dump(struct mpp_dev *mpp)
+{
+	struct rkvdec2_dev *dec = to_rkvdec2_dev(mpp);
+	struct rkvdec_link_dev *dev = dec->link_dec;
+
+	rkvdec_link_status_update(dev);
