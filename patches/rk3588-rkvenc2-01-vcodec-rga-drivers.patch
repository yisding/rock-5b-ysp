+#define RKVDEC_REG_CLR_CACHE2_BASE	0x590
+
+#define RKVDEC_CACHE_PERMIT_CACHEABLE_ACCESS	BIT(0)
+#define RKVDEC_CACHE_PERMIT_READ_ALLOCATE	BIT(1)
