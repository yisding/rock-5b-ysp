+	case RGA_FORMAT_BGRA_8888:
+	case RGA_FORMAT_BGRX_8888:
+		win_format = 0x6;
+		pixel_width = 4;
+		win_interleaved = 2;
+		break;
+	case RGA_FORMAT_ARGB_8888:
+	case RGA_FORMAT_XRGB_8888:
+		win_format = 0x9;
+		pixel_width = 4;
+		win_interleaved = 2;
+		break;
+	case RGA_FORMAT_ABGR_8888:
+	case RGA_FORMAT_XBGR_8888:
+		win_format = 0x7;
+		pixel_width = 4;
+		win_interleaved = 2;
