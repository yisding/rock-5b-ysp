+
+#define GET_GCD(n1, n2) \
+	({ \
+		int i; \
+		int gcd = 1; \
+		for (i = 1; i <= (n1) && i <= (n2); i++) { \
+			if ((n1) % i == 0 && (n2) % i == 0) \
+				gcd = i; \
+		} \
+		gcd; \
+	})
+#define GET_LCM(n1, n2, gcd) (((n1) * (n2)) / gcd)
