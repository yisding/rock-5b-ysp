+		pixel_width = 2;
+		win_interleaved = 2;
+		win_pix_swp = 1;
+		break;
+	case RGA_FORMAT_BGR_565:
+		win_format = 0x4;
+		pixel_width = 2;
+		win_interleaved = 2;
+		break;
