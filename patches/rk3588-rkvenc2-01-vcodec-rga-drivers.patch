+# SPDX-License-Identifier: GPL-2.0
+config ROCKCHIP_MPP_SERVICE
+	tristate "Rockchip MPP service framework"
+	depends on ARCH_ROCKCHIP
+	default y
+	select DMA_SHARED_BUFFER
+	help
+	  Rockchip Media Process Platform (MPP) service framework. Provides the
+	  /dev/mpp_service char device and the shared task/IOMMU/clk/pm core used
+	  by the Rockchip hardware codec device drivers.
+
+if ROCKCHIP_MPP_SERVICE
+
+config ROCKCHIP_MPP_PROC_FS
+	bool "Rockchip MPP procfs"
+	default y
+	help
+	  Expose per-device runtime state under /proc/mpp_service.
+
+config ROCKCHIP_MPP_RKVENC2
+	bool "RKVENC2 (VEPU580) H.264/H.265 encoder"
+	default y
+	help
+	  Hardware video encoder VEPU580 (rkvenc2) found on RK3588. H.264 and
+	  H.265 encode.
+
+config ROCKCHIP_MPP_RKVENC2_DEVFREQ
+	bool "RKVENC2 devfreq/OPP/thermal (tier-2)"
+	depends on ROCKCHIP_MPP_RKVENC2 && PM_DEVFREQ
+	default n
+	help
+	  Enable the devfreq/OPP/system-monitor DVFS island for rkvenc2. Off by
