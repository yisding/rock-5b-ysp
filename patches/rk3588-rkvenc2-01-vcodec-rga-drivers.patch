+#endif
+
+#ifdef CONFIG_ROCKCHIP_RGA_PROC_FS
+	mutex_init(&debugger->procfs_lock);
+	INIT_LIST_HEAD(&debugger->procfs_entry_list);
+#endif
+
+	rga_debugfs_init();
+	rga_procfs_init();
