From 82f44497eb1cd306bdcfaac75aadae34d4ea727f Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:38:30 -0700
Subject: [PATCH 58/65] media: rockchip: rga: allocate page tables by element
 size

Plain-language impact:
Page-table allocations use the size of the table element, not the size of a pointer.

Kernel details:
rga_mm_set_mmu_base() allocates a uint32_t page_table but used sizeof(uint32_t *). Use sizeof(*page_table) in both allocations.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/rga3/rga_mm.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/video/rockchip/rga3/rga_mm.c b/drivers/video/rockchip/rga3/rga_mm.c
index 7ad1118..867ea73 100644
--- a/drivers/video/rockchip/rga3/rga_mm.c
+++ b/drivers/video/rockchip/rga3/rga_mm.c
@@ -1283,7 +1283,7 @@ static int rga_mm_set_mmu_base(struct rga_job *job,
 
 		if (job->flags & RGA_JOB_USE_HANDLE) {
 			page_table = (uint32_t *)rga_get_free_pages(GFP_KERNEL | GFP_DMA32,
-				&order, page_count * sizeof(uint32_t *));
+				&order, page_count * sizeof(*page_table));
 			if (page_table == NULL) {
 				rga_job_err(job, "%s can not alloc pages for page_table, order = %d\n",
 					__func__, order);
@@ -1348,7 +1348,7 @@ static int rga_mm_set_mmu_base(struct rga_job *job,
 
 		if (job->flags & RGA_JOB_USE_HANDLE) {
 			page_table = (uint32_t *)rga_get_free_pages(GFP_KERNEL | GFP_DMA32,
-				&order, page_count * sizeof(uint32_t *));
+				&order, page_count * sizeof(*page_table));
 			if (page_table == NULL) {
 				rga_job_err(job, "%s can not alloc pages for page_table, order = %d\n",
 					__func__, order);
-- 
