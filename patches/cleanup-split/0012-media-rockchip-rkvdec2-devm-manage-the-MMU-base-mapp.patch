From 139aa9af2d2117178a1e5381974860cdbf1da0ca Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:18:29 -0700
Subject: [PATCH 12/65] media: rockchip: rkvdec2: devm-manage the MMU base
 mapping

Plain-language impact:
The decoder MMU register mapping is automatically released on probe failure and removal.

Kernel details:
Use devm_ioremap() for dec->mmu_base and remove the manual iounmap() path.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/mpp/mpp_rkvdec2.c | 6 +-----
 1 file changed, 1 insertion(+), 5 deletions(-)

diff --git a/drivers/video/rockchip/mpp/mpp_rkvdec2.c b/drivers/video/rockchip/mpp/mpp_rkvdec2.c
index 0ed4877..4dc684c 100644
--- a/drivers/video/rockchip/mpp/mpp_rkvdec2.c
+++ b/drivers/video/rockchip/mpp/mpp_rkvdec2.c
@@ -1953,7 +1953,7 @@ static int rkvdec2_core_probe(struct platform_device *pdev)
 		dev_err(dev, "probe sub driver failed\n");
 		return ret;
 	}
-	dec->mmu_base = ioremap(dec->mpp.io_base + 0x600, 0x80);
+	dec->mmu_base = devm_ioremap(dev, dec->mpp.io_base + 0x600, 0x80);
 	if (!dec->mmu_base)
 		dev_err(dev, "mmu base map failed!\n");
 
@@ -2136,10 +2136,6 @@ static void rkvdec2_remove(struct platform_device *pdev)
 		struct rkvdec2_dev *dec = to_rkvdec2_dev(mpp);
 
 		dev_info(dev, "remove device\n");
-		if (dec->mmu_base) {
-			iounmap(dec->mmu_base);
-			dec->mmu_base = NULL;
-		}
 		rkvdec2_free_rcbbuf(pdev, dec);
 		mpp_dev_remove(mpp);
 		rkvdec2_procfs_remove(mpp);
-- 
