From 5f2c38d77579371c9e13d6eac3fce280f5e558b9 Mon Sep 17 00:00:00 2001
From: Yi Ding <yi.s.ding@gmail.com>
Date: Wed, 1 Jul 2026 06:21:34 -0700
Subject: [PATCH 27/65] media: rockchip: mpp: stop workers on service probe
 failure

Plain-language impact:
Worker threads started during service probe are stopped if a later step fails.

Kernel details:
Add fail_register cleanup that flushes and stops each non-NULL kworker_task before class_destroy().

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
Signed-off-by: Yi Ding <yi.s.ding@gmail.com>
---
 drivers/video/rockchip/mpp/mpp_service.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/drivers/video/rockchip/mpp/mpp_service.c b/drivers/video/rockchip/mpp/mpp_service.c
index 23601d651ae8..07f3b84f1452 100644
--- a/drivers/video/rockchip/mpp/mpp_service.c
+++ b/drivers/video/rockchip/mpp/mpp_service.c
@@ -506,6 +506,14 @@ static int mpp_service_probe(struct platform_device *pdev)
 	return 0;
 
 fail_register:
+	for (i = 0; i < srv->taskqueue_cnt; i++) {
+		queue = srv->task_queues[i];
+		if (queue && queue->kworker_task) {
+			kthread_flush_worker(&queue->worker);
+			kthread_stop(queue->kworker_task);
+			queue->kworker_task = NULL;
+		}
+	}
 	class_destroy(srv->cls);
 
 	return ret;
-- 
