From 4e29ccb880e9a5361801c5d0582bdd57c9895d61 Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:26:05 -0700
Subject: [PATCH 26/65] media: rockchip: mpp: normalize failed worker threads

Plain-language impact:
A failed kthread creation no longer leaves an ERR_PTR that teardown treats as a task.

Kernel details:
Check IS_ERR() after kthread_run(), log the failure, and store NULL so cleanup skips that queue.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/mpp/mpp_service.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/drivers/video/rockchip/mpp/mpp_service.c b/drivers/video/rockchip/mpp/mpp_service.c
index 852c029..1eab6e5 100644
--- a/drivers/video/rockchip/mpp/mpp_service.c
+++ b/drivers/video/rockchip/mpp/mpp_service.c
@@ -442,6 +442,10 @@ static int mpp_service_probe(struct platform_device *pdev)
 		kthread_init_worker(&queue->worker);
 		queue->kworker_task = kthread_run(kthread_worker_fn, &queue->worker,
 						  "mpp_worker_%d", i);
+		if (IS_ERR(queue->kworker_task)) {
+			dev_err(dev, "failed to run mpp_worker_%d\n", i);
+			queue->kworker_task = NULL;
+		}
 		srv->task_queues[i] = queue;
 	}
 
