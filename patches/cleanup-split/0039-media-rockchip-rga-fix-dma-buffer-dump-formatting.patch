From b7c99d3da6a375a4a08e7d034f98f098597951ae Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:29:41 -0700
Subject: [PATCH 39/65] media: rockchip: rga: fix dma buffer dump formatting

Plain-language impact:
Debug output now separates the IOVA and SGT fields.

Kernel details:
Add the missing separator between iova and sgt in rga_mm_session_show().

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/rga3/rga_debugger.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/video/rockchip/rga3/rga_debugger.c b/drivers/video/rockchip/rga3/rga_debugger.c
index 3e25bf9..ddce4b5 100644
--- a/drivers/video/rockchip/rga3/rga_debugger.c
+++ b/drivers/video/rockchip/rga3/rga_debugger.c
@@ -282,7 +282,7 @@ static int rga_mm_session_show(struct seq_file *m, void *data)
 				break;
 
 			seq_puts(m, "dma_buffer:\n");
-			seq_printf(m, "\t dma_buf = %p, iova = 0x%lxsgt = 0x%p, size = %ld, map_core = 0x%x\n",
+			seq_printf(m, "\t dma_buf = %p, iova = 0x%lx, sgt = 0x%p, size = %ld, map_core = 0x%x\n",
 				   dump_buffer->dma_buffer->dma_buf,
 				   (unsigned long)dump_buffer->dma_buffer->iova,
 				   dump_buffer->dma_buffer->sgt,
-- 
2.53.0

