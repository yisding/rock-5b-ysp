From 2f5a1200b5c4d07018c0df9d15389c9dc122651e Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:15:08 -0700
Subject: [PATCH 04/65] media: rockchip: mpp: flush last session-switch message

Plain-language impact:
A SET_SESSION_FD message at the end of a batch is now either queued or returned to the idle pool instead of being abandoned.

Kernel details:
Before the last-message return, handle a live msgs object: task_msgs_add() it if it has requests, otherwise put_task_msgs(), then clear the local pointer.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/mpp/mpp_common.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/drivers/video/rockchip/mpp/mpp_common.c b/drivers/video/rockchip/mpp/mpp_common.c
index f903aa0..6c5a5bb 100644
--- a/drivers/video/rockchip/mpp/mpp_common.c
+++ b/drivers/video/rockchip/mpp/mpp_common.c
@@ -1607,8 +1607,16 @@ next:
 
 session_switch_done:
 		/* session id should NOT be the last message */
-		if (last)
+		if (last) {
+			if (msgs) {
+				if (msgs->req_cnt)
+					task_msgs_add(msgs, head);
+				else
+					put_task_msgs(msgs);
+				msgs = NULL;
+			}
 			return 0;
+		}
 
 		goto next;
 	}
