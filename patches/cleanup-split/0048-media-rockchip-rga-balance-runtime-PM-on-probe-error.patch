From 624e8c69e1032f4e565fc438c9b50de7af3e54f2 Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:34:46 -0700
Subject: [PATCH 48/65] media: rockchip: rga: balance runtime PM on probe error

Plain-language impact:
If clock enable fails during probe, the runtime-PM usage count is released.

Kernel details:
Use pm_runtime_resume_and_get() and call pm_runtime_put_sync() before pm_disable when clk_bulk_prepare_enable() fails.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/rga3/rga_drv.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/video/rockchip/rga3/rga_drv.c b/drivers/video/rockchip/rga3/rga_drv.c
index dd67986..dbcebfa 100644
--- a/drivers/video/rockchip/rga3/rga_drv.c
+++ b/drivers/video/rockchip/rga3/rga_drv.c
@@ -1437,7 +1437,7 @@ static int rga_drv_probe(struct platform_device *pdev)
 	device_init_wakeup(dev, true);
 	pm_runtime_enable(scheduler->dev);
 
-	ret = pm_runtime_get_sync(scheduler->dev);
+	ret = pm_runtime_resume_and_get(scheduler->dev);
 	if (ret < 0) {
 		dev_err(dev, "failed to get pm runtime, ret = %d\n", ret);
 		goto pm_disable;
@@ -1446,6 +1446,7 @@ static int rga_drv_probe(struct platform_device *pdev)
 	ret = clk_bulk_prepare_enable(scheduler->num_clks, scheduler->clks);
 	if (ret < 0) {
 		dev_err(dev, "failed to enable clk\n");
+		pm_runtime_put_sync(scheduler->dev);
 		goto pm_disable;
 	}
 #endif /* #ifndef RGA_DISABLE_PM */
