From 3f8a37b284bb0a9ea3db25517faebe04a95ab746 Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:38:30 -0700
Subject: [PATCH 64/65] media: rockchip: rga: hoist rotation swap calculation

Plain-language impact:
Avoids recomputing an invariant rotation check for every scheduler candidate.

Kernel details:
Compute need_swap once before the scheduler loop; the expression depends only on rga_base, not scheduler data.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/rga3/rga_policy.c | 13 ++++++-------
 1 file changed, 6 insertions(+), 7 deletions(-)

diff --git a/drivers/video/rockchip/rga3/rga_policy.c b/drivers/video/rockchip/rga3/rga_policy.c
index 5b22551..5889d27 100644
--- a/drivers/video/rockchip/rga3/rga_policy.c
+++ b/drivers/video/rockchip/rga3/rga_policy.c
@@ -327,6 +327,12 @@ int rga_job_assign(struct rga_job *job)
 
 	feature = rga_set_feature(rga_base);
 
+	/* some mode rotate 90/270 need swap dst_width/dst_height */
+	if (((rga_base->rotate_mode & 0x0f) == 1) &&
+	    ((rga_base->sina == 65536 && rga_base->cosa == 0) ||
+	     (rga_base->sina == -65536 && rga_base->cosa == 0)))
+		need_swap = true;
+
 	/* function */
 	for (i = 0; i < rga_drvdata->num_of_scheduler; i++) {
 		data = rga_drvdata->scheduler[i]->data;
@@ -357,13 +363,6 @@ int rga_job_assign(struct rga_job *job)
 			}
 		}
 
-		/* some mode rotate 90/270 need swap dst_width/dst_height  */
-		if (((rga_base->rotate_mode & 0x0f) == 1) &&
-			((rga_base->sina == 65536 && rga_base->cosa == 0) ||
-			(rga_base->sina == -65536 && rga_base->cosa == 0))) {
-			need_swap = true;
-		}
-
 		/* only colorfill need single win (colorpalette?) */
 		if (!(feature & 1)) {
 			if (src1->yrgb_addr > 0) {
-- 
