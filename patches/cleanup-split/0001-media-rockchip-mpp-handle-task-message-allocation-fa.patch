From 094b317cc7276fc99723d2587e8b274e5b92f3cd Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:15:08 -0700
Subject: [PATCH 01/65] media: rockchip: mpp: handle task message allocation
 failure

Plain-language impact:
If memory allocation fails while preparing an MPP message batch, the driver now fails cleanly instead of crashing or leaking the held session fd.

Kernel details:
get_task_msgs() can now return NULL after kzalloc() failure. The SET_SESSION_FD path checks that return before dereferencing msgs and fdput()s the struct fd acquired for the session switch.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/mpp/mpp_common.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/drivers/video/rockchip/mpp/mpp_common.c b/drivers/video/rockchip/mpp/mpp_common.c
index a66a51a..668a3f9 100644
--- a/drivers/video/rockchip/mpp/mpp_common.c
+++ b/drivers/video/rockchip/mpp/mpp_common.c
@@ -248,6 +248,8 @@ static struct mpp_task_msgs *get_task_msgs(struct mpp_session *session)
 	spin_unlock_irqrestore(&session->lock_msgs, flags);
 
 	msgs = kzalloc(sizeof(*msgs), GFP_KERNEL);
+	if (!msgs)
+		return NULL;
 	task_msgs_init(msgs, session);
 	INIT_LIST_HEAD(&msgs->list_session);
 
@@ -1578,7 +1580,11 @@ next:
 		/* switch session */
 		session = fd_file(f)->private_data;
 		msgs = get_task_msgs(session);
-
+		if (!msgs) {
+			/* alloc failed: release the held fd, don't deref NULL */
+			fdput(f);
+			goto session_switch_done;
+		}
 		if (fd_file(f)->private_data == session)
 			msgs->ext_fd = bat_msg.fd;
 
