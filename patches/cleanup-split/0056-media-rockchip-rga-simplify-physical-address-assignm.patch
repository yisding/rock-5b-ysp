From c43f9dbef90555887be807eaf980db04f7fb0f33 Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:36:54 -0700
Subject: [PATCH 56/65] media: rockchip: rga: simplify physical address
 assignment

Plain-language impact:
Removes a no-op conditional expression from DMA-buffer mapping setup.

Kernel details:
internal_buffer->phys_addr = phys_addr ? phys_addr : 0 is equivalent to assigning phys_addr directly.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/rga3/rga_mm.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/video/rockchip/rga3/rga_mm.c b/drivers/video/rockchip/rga3/rga_mm.c
index f6b1ff5..08283da 100644
--- a/drivers/video/rockchip/rga3/rga_mm.c
+++ b/drivers/video/rockchip/rga3/rga_mm.c
@@ -499,7 +499,7 @@ static int rga_mm_map_dma_buffer(struct rga_external_buffer *external_buffer,
 
 	internal_buffer->dma_buffer = buffer;
 	internal_buffer->mm_flag = mm_flag;
-	internal_buffer->phys_addr = phys_addr ? phys_addr : 0;
+	internal_buffer->phys_addr = phys_addr;
 	internal_buffer->size = buffer->size - buffer->offset;
 	internal_buffer->scheduler = scheduler;
 
