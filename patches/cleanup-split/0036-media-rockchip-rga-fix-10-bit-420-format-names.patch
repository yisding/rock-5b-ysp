From 8d2b8ed209e4240c51449bfa0057e747958212bd Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:27:46 -0700
Subject: [PATCH 36/65] media: rockchip: rga: fix 10-bit 420 format names

Plain-language impact:
Debug output now names the two 10-bit 4:2:0 semi-planar formats correctly.

Kernel details:
rga_get_format_name() returned the YCrCb string for RGA_FORMAT_YCbCr_420_SP_10B and vice versa. Swap the two return strings.

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/rga3/rga_common.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/video/rockchip/rga3/rga_common.c b/drivers/video/rockchip/rga3/rga_common.c
index d941107..09b6e7d 100644
--- a/drivers/video/rockchip/rga3/rga_common.c
+++ b/drivers/video/rockchip/rga3/rga_common.c
@@ -304,9 +304,9 @@ const char *rga_get_format_name(uint32_t format)
 		return "UYVY420";
 
 	case RGA_FORMAT_YCbCr_420_SP_10B:
-		return "YCrCb420SP10B";
-	case RGA_FORMAT_YCrCb_420_SP_10B:
 		return "YCbCr420SP10B";
+	case RGA_FORMAT_YCrCb_420_SP_10B:
+		return "YCrCb420SP10B";
 	case RGA_FORMAT_YCbCr_422_SP_10B:
 		return "YCbCr422SP10B";
 	case RGA_FORMAT_YCrCb_422_SP_10B:
-- 
2.53.0

