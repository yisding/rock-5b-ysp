From ff04dfb2cb4593cb06ea72cae06c27d142945dc3 Mon Sep 17 00:00:00 2001
From: Split <split@example.invalid>
Date: Tue, 30 Jun 2026 22:38:30 -0700
Subject: [PATCH 62/65] media: rockchip: rga: unmap buffer on id allocation
 failure

Plain-language impact:
A mapped buffer is unmapped if allocating its userspace handle fails.

Kernel details:
When idr_alloc_cyclic() fails in rga_mm_import_buffer(), jump to UNMAP_AND_FREE_BUFFER so rga_mm_unmap_buffer() runs before kfree(internal_buffer).

Source: split from patches/cleanup-draft after docs/11-bsp-audit.md verification.
---
 drivers/video/rockchip/rga3/rga_mm.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/drivers/video/rockchip/rga3/rga_mm.c b/drivers/video/rockchip/rga3/rga_mm.c
index a738718..3f5ffc9 100644
--- a/drivers/video/rockchip/rga3/rga_mm.c
+++ b/drivers/video/rockchip/rga3/rga_mm.c
@@ -2464,7 +2464,7 @@ int rga_mm_import_buffer(struct rga_external_buffer *external_buffer,
 		ret = new_id;
 
 		mutex_unlock(&mm->lock);
-		goto FREE_INTERNAL_BUFFER;
+		goto UNMAP_AND_FREE_BUFFER;
 	}
 
 	internal_buffer->handle = new_id;
@@ -2483,6 +2483,8 @@ int rga_mm_import_buffer(struct rga_external_buffer *external_buffer,
 
 	return internal_buffer->handle;
 
+UNMAP_AND_FREE_BUFFER:
+	rga_mm_unmap_buffer(internal_buffer);
 FREE_INTERNAL_BUFFER:
 	kfree(internal_buffer);
 
