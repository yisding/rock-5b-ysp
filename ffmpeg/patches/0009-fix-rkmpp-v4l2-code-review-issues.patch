-        (((mod >> 56) & 0xff) == DRM_FORMAT_MOD_VENDOR_ROCKCHIP) && \
-        (((mod >> 52) & DRM_FORMAT_MOD_ROCKCHIP_TYPE_MASK) == DRM_FORMAT_MOD_ROCKCHIP_TYPE_RFBC)
+        (((((mod) >> 56) & 0xff) == DRM_FORMAT_MOD_VENDOR_ROCKCHIP) && \
